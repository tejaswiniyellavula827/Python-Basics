class CIRCLE:
    def __init__(self):
        x=int(input("Enter circle radius"))
        self.radius=x
    def display(self):
        print("Area of circle is ",3.14*self.radius**2)
    
a=int(input("Enter number of circles"))
circles=[]
for i in range(a):
    c=CIRCLE()
    circles.append(c)
    c.display()
    print("-------------------------------")
print(circles)
